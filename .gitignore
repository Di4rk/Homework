# 1. BẢO MẬT (TUYỆT ĐỐI KHÔNG PUSH LÊN)
# Chứa mật khẩu, API keys, chuỗi kết nối database...
.env
*.env
.env.*
secret/
credentials.json

# 2. HỆ ĐIỀU HÀNH (Rác của Windows & macOS)
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride

# 3. CÁC IDE & EDITOR PHỔ BIẾN
# Visual Studio (C++/C#)
.vs/
*.vsidx
*.suo
*.user
*.slnx.sqlite
*.db

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.code-workspace

# JetBrains (CLion, IntelliJ, PyCharm, WebStorm...)
.idea/
cmake-build-*/
*.iml
*.iws

# 4. C/C++ (Đặc trị rác biên dịch và file thực thi)
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
